rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    // Game Masters register their auth uid in config/admin.gmUids when they
    // unlock with the passcode (see Auth._registerGm in js/srmpc-core.js).
    // GM sessions get UNRESTRICTED read/write to every collection below via
    // the wildcard match — total control, bypassing any per-collection rule.
    //
    // Trust note: this app's security model is passcode + authenticated
    // writes (a friends-league, not a bank). The gmUids registry is what
    // future per-field validation rules key off — any rule you tighten for
    // normal players below must stay open for isGM().
    function isGM() {
      return request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/config/admin).data.get('gmUids', []);
    }

    // ----- Wallet isolation (js/srmpc-wallet.js) -----
    // users/{uid}.balance = the Player Wallet. teams/{id}.budget = the Team
    // Wallet. They are two different fields on two different documents —
    // never the same number, even when one human owns both. Every
    // legitimate wallet-touching write in the app changes ONLY the wallet
    // field (+ updatedAt), or one of a short list of known combos (the
    // difficulty picker seeding balance alongside difficulty/roleDifficulty;
    // team founding/purchase seeding budget alongside ownership fields) —
    // never bundled with an unrelated field, which is what a compromised or
    // careless client smuggling a privilege change alongside a wallet edit
    // would look like.
    //
    // Honest limit: this is a client-direct Firestore app with no Cloud
    // Functions backend, so rules can constrain the SHAPE of a wallet write
    // (isolated, narrow, ledger-adjacent) but cannot cryptographically prove
    // a paired ledger row is genuine — a determined attacker with full
    // client access could still forge one. True tamper-proof enforcement
    // needs server-authoritative Cloud Functions; out of scope here.
    function userWriteOk() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return !changed.hasAny(['balance'])
        || changed.hasOnly(['balance', 'updatedAt'])
        || changed.hasOnly(['balance', 'difficulty', 'walletInitialized', 'roleDifficulty', 'updatedAt']);
    }
    function teamWriteOk() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return !changed.hasAny(['budget'])
        || changed.hasOnly(['budget', 'updatedAt'])
        || changed.hasOnly(['budget', 'tier', 'updatedAt'])
        || changed.hasOnly(['budget', 'ownerUid', 'isEstablished', 'updatedAt'])
        || changed.hasOnly(['budget', 'ownerUid', 'isEstablished', 'marketValue', 'tier', 'updatedAt']);
    }

    // ----- Global GM override: the Game Master may edit ANYTHING -----
    match /{document=**} {
      allow read, write: if isGM();
    }

    // ----- Public-read league data (guests can browse; members write) -----
    match /games/{doc}    { allow read: if true; allow write: if isAuthenticated(); }
    match /series/{doc}   { allow read: if true; allow write: if isAuthenticated(); }
    match /seasons/{doc}  { allow read: if true; allow write: if isAuthenticated(); }
    match /races/{doc}    { allow read: if true; allow write: if isAuthenticated(); }
    match /drivers/{doc}  { allow read: if true; allow write: if isAuthenticated(); }
    match /challenges/{doc} { allow read: if true; allow write: if isAuthenticated(); }
    match /staff/{doc}      { allow read: if true; allow write: if isAuthenticated(); }
    match /news/{doc}       { allow read: if true; allow write: if isAuthenticated(); }
    match /tracks/{doc}     { allow read: if true; allow write: if isAuthenticated(); }
    match /sponsors/{doc}   { allow read: if true; allow write: if isAuthenticated(); }
    match /recruitment/{doc} { allow read: if isAuthenticated(); allow write: if isAuthenticated(); }
    match /ledger/{doc}       { allow read: if isAuthenticated(); allow write: if isAuthenticated(); }

    // Contracts: everyone may read and create (signings happen through
    // negotiations), but an ACTIVE contract's core terms can only be
    // rewritten by a GM or a party to the contract — a random member
    // can't edit someone else's salary/buyout/status.
    match /contracts/{doc} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if isAuthenticated() && (
        // parties to the deal (talent, paying owner, or sponsor)…
        resource.data.get('personUid', '') == request.auth.uid
        || resource.data.get('ownerUid', '') == request.auth.uid
        || resource.data.get('sponsorUid', '') == request.auth.uid
        // …or league-owned contracts (no player owner) stay member-editable
        // so race-day settlement and GM-proxy flows keep working
        || resource.data.get('ownerUid', null) == null
      );
    }

    // Teams: open like the other league data, except the isolated Team
    // Wallet (budget) — see teamWriteOk() above.
    match /teams/{doc} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if isAuthenticated() && teamWriteOk();
    }

    // Negotiations: only the two sides may move an open deal.
    match /negotiations/{doc} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.get('sideAUid', null) == request.auth.uid
        || resource.data.get('sideBUid', null) == request.auth.uid
        || resource.data.get('sideAUid', null) == null
        || resource.data.get('sideBUid', null) == null
      );
    }

    // ----- Member-only data -----
    // Users: open like before, except the isolated Player Wallet (balance)
    // — see userWriteOk() above.
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if isAuthenticated() && userWriteOk();
    }
    match /roleProfiles/{doc}    { allow read: if isAuthenticated(); allow write: if isAuthenticated(); }
    match /challengeClaims/{doc} { allow read: if isAuthenticated(); allow write: if isAuthenticated(); }
    match /raceSignups/{doc}     { allow read: if isAuthenticated(); allow write: if isAuthenticated(); }

    // ----- App config (admin passcode hash, GM registry, future settings) -----
    match /config/{doc}          { allow read: if true; allow write: if isAuthenticated(); }
  }
}
