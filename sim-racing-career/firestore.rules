rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // DEVELOPMENT RULES — open access while Anonymous Authentication is being set up.
    // TODO: After enabling Anonymous sign-in in Firebase Console, switch to production rules below.
    match /{document=**} {
      allow read, write: if true;
    }

    // PRODUCTION RULES — uncomment and redeploy once Anonymous Authentication is enabled.
    // function isSignedIn() {
    //   return request.auth != null;
    // }
    // match /{document=**} {
    //   allow read, write: if isSignedIn();
    // }
    // match /users/{userId} {
    //   allow read, write: if isSignedIn() && request.auth.uid == userId;
    // }
  }
}
